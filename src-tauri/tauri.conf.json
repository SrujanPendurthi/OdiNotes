{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OdiNotes",
  "version": "0.1.0",
  "identifier": "com.odinotes.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OdiNotes",
        "width": 1100,
        "height": 720,
        "minWidth": 200,
        "minHeight": 200,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Lightweight Obsidian-style Markdown notes",
    "longDescription": "OdiNotes is a lightweight, hyper-efficient Obsidian-style Markdown note-taking app, optimized for low RAM/CPU usage.",
    "copyright": "Copyright © 2026 OdiNotes",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
